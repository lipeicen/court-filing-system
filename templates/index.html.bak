<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>法院保全案件管理系统</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; background: #f5f7fa; color: #333; }
        .header { background: #1a237e; color: white; padding: 15px 30px; display: flex; justify-content: space-between; align-items: center; }
        .header h1 { font-size: 20px; }
        .header-actions { display: flex; gap: 10px; align-items: center; }
        .header a, .header button { color: white; text-decoration: none; background: #3949ab; padding: 8px 20px; border-radius: 4px; border: none; cursor: pointer; font-size: 14px; }
        .header a:hover, .header button:hover { background: #5c6bc0; }
        .header .btn-secondary { background: #546e7a; }
        .header .btn-secondary:hover { background: #78909c; }
        .header .btn-success { background: #2e7d32; }
        .header .btn-success:hover { background: #43a047; }
        .container { max-width: 1400px; margin: 30px auto; padding: 0 20px; }
        .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: white; padding: 20px; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .stat-card h3 { font-size: 14px; color: #666; margin-bottom: 8px; }
        .stat-card .number { font-size: 32px; font-weight: bold; color: #1a237e; }
        .case-table { background: white; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); overflow: hidden; }
        .case-table table { width: 100%; border-collapse: collapse; }
        .case-table th { background: #f8f9fa; padding: 12px 15px; text-align: left; font-weight: 600; color: #555; border-bottom: 2px solid #e9ecef; }
        .case-table td { padding: 12px 15px; border-bottom: 1px solid #e9ecef; }
        .case-table tr:hover { background: #f8f9fa; }
        .case-table a { color: #1a237e; text-decoration: none; }
        .case-table a:hover { text-decoration: underline; }
        .badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 12px; }
        .badge-deposit { background: #e3f2fd; color: #1565c0; }
        .badge-house { background: #f3e5f5; color: #7b1fa2; }
        .badge-stock { background: #e8f5e9; color: #2e7d32; }
        .badge-vehicle { background: #fff3e0; color: #ef6c00; }
        .badge-equity { background: #fce4ec; color: #c62828; }
        .flash { padding: 12px 20px; margin-bottom: 20px; border-radius: 4px; }
        .flash-success { background: #e8f5e9; color: #2e7d32; border: 1px solid #c8e6c9; }
        .flash-error { background: #ffebee; color: #c62828; border: 1px solid #ffcdd2; }
        .empty { text-align: center; padding: 60px; color: #999; }
        .upload-form { display: none; position: absolute; top: 50px; right: 30px; background: white; padding: 20px; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.15); z-index: 100; min-width: 300px; }
        .upload-form.show { display: block; }
        .upload-form h4 { margin-bottom: 15px; color: #1a237e; }
        .upload-form input[type="file"] { margin-bottom: 15px; width: 100%; }
        .upload-form .form-actions { display: flex; gap: 10px; }
        .upload-form button { flex: 1; padding: 8px; border: none; border-radius: 4px; cursor: pointer; }
        .upload-form .btn-submit { background: #2e7d32; color: white; }
        .upload-form .btn-cancel { background: #e0e0e0; color: #333; }
        .header-wrapper { position: relative; }
    </style>
</head>
<body>
    <div class="header-wrapper">
        <div class="header">
            <h1>🏛️ 法院保全案件管理系统</h1>
            <div class="header-actions">
                <a href="/template/download" class="btn-secondary">📥 下载模板</a>
                <button type="button" class="btn-success" onclick="toggleUpload()">📤 批量导入</button>
                <a href="/case/add">+ 新增案件</a>
            </div>
        </div>
        <div class="upload-form" id="uploadForm">
            <h4>批量导入案件</h4>
            <form method="POST" action="/template/upload" enctype="multipart/form-data">
                <input type="file" name="excel_file" accept=".xlsx,.xls" required>
                <div class="form-actions">
                    <button type="submit" class="btn-submit">上传</button>
                    <button type="button" class="btn-cancel" onclick="toggleUpload()">取消</button>
                </div>
            </form>
        </div>
    </div>
    
    <div class="container">
        {% with messages = get_flashed_messages(with_categories=true) %}
            {% if messages %}
                {% for category, message in messages %}
                    <div class="flash flash-{{ category }}">{{ message }}</div>
                {% endfor %}
            {% endif %}
        {% endwith %}
        
        <div class="stats">
            <div class="stat-card">
                <h3>总案件数</h3>
                <div class="number">{{ cases|length }}</div>
            </div>
            <div class="stat-card">
                <h3>诉前保全</h3>
                <div class="number">{{ cases|selectattr('preserve_type', 'equalto', '诉前保全')|list|length }}</div>
            </div>
            <div class="stat-card">
                <h3>诉讼保全</h3>
                <div class="number">{{ cases|selectattr('preserve_type', 'equalto', '诉讼保全')|list|length }}</div>
            </div>
            <div class="stat-card">
                <h3>本月新增</h3>
                <div class="number">--</div>
            </div>
        </div>
        
        <div class="case-table">
            <table>
                <thead>
                    <tr>
                        <th>案件编号</th>
                        <th>案件名称</th>
                        <th>申请人</th>
                        <th>被申请人</th>
                        <th>保全金额</th>
                        <th>法院</th>
                        <th>财产类型</th>
                        <th>担保方式</th>
                        <th>创建时间</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                    {% for case in cases %}
                    <tr>
                        <td><a href="/case/{{ case.id }}">{{ case.case_no }}</a></td>
                        <td>{{ case.case_name or '-' }}</td>
                        <td>{{ case.applicant_name or '-' }}</td>
                        <td>{{ case.respondent_name or '-' }}</td>
                        <td>{{ "%.2f"|format(case.preserve_amount|float) if case.preserve_amount else '-' }}</td>
                        <td>{{ case.court_name or '-' }}</td>
                        <td>
                            {% if case.property_type == '存款' %}
                                <span class="badge badge-deposit">存款</span>
                            {% elif case.property_type == '房产' %}
                                <span class="badge badge-house">房产</span>
                            {% elif case.property_type == '股票' %}
                                <span class="badge badge-stock">股票</span>
                            {% elif case.property_type == '车辆' %}
                                <span class="badge badge-vehicle">车辆</span>
                            {% elif case.property_type == '股权' %}
                                <span class="badge badge-equity">股权</span>
                            {% else %}
                                {{ case.property_type or '-' }}
                            {% endif %}
                        </td>
                        <td>{{ case.guarantee_type or '-' }}</td>
                        <td>{{ case.created_at.strftime('%Y-%m-%d') if case.created_at else '-' }}</td>
                        <td><a href="/case/{{ case.id }}">查看</a></td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="10" class="empty">暂无案件数据</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    <script>
        function toggleUpload() {
            document.getElementById('uploadForm').classList.toggle('show');
        }
        // Close upload form when clicking outside
        document.addEventListener('click', function(e) {
            const form = document.getElementById('uploadForm');
            const btn = e.target.closest('button');
            if (!form.contains(e.target) && !(btn && btn.textContent.includes('批量导入'))) {
                form.classList.remove('show');
            }
        });
    </script>
</body>
</html>
